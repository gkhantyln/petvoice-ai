# .env.example
# Bu dosya, uygulama için gerekli ortam değişkenlerinin örneğidir
# Kullanmak için bu dosyayı .env olarak kopyalayın ve değerleri doldurun

# Flask için gizli anahtar (güvenli bir değer oluşturun)
SECRET_KEY=your-secret-key-here-change-this-in-production

# Google Gemini API Anahtarları
# https://aistudio.google.com/app/apikey adresinden alabilirsiniz
# Birden fazla anahtar ekleyebilirsiniz (failover için)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_API_KEY_1=your-backup-google-api-key-1
GOOGLE_API_KEY_2=your-backup-google-api-key-2

# OpenAI API Anahtarları (Opsiyonel)
# https://platform.openai.com/api-keys adresinden alabilirsiniz
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_KEY_1=your-backup-openai-api-key-1

# Anthropic Claude API Anahtarları (Opsiyonel)
# https://console.anthropic.com/ adresinden alabilirsiniz
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_KEY_1=your-backup-anthropic-api-key-1

# Veritabanı bağlantıları
# SQLite (Geliştirme ortamı için önerilen)
DATABASE_URL=sqlite:///petvoice.db
DEV_DATABASE_URL=sqlite:///petvoice_dev.db
TEST_DATABASE_URL=sqlite:///test.db

# PostgreSQL (Production ortamı için önerilen)
# DATABASE_URL=postgresql://username:password@localhost/petvoice
# DEV_DATABASE_URL=postgresql://username:password@localhost/petvoice_dev

# Dosya yükleme klasörü
UPLOAD_FOLDER=uploads

# E-posta yapılandırması (isteğe bağlı)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password

# Redis yapılandırması (Celery için - isteğe bağlı)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Flask yapılandırması
# Seçenekler: development, testing, production
FLASK_CONFIG=development
